# NYC Real Estate API (RapidAPI)
# Get your key at https://rapidapi.com/realestator/api/nyc-real-estate-api
RAPIDAPI_KEY=your_rapidapi_key_here
ENABLE_AUTOMATED_OUTREACH=false
# Rental flow: log 404/errors when probing building URLs (set to 1 to see "Requested listing id not found" etc.)
# RENTAL_DEBUG=1
# Rentals/search fallback is on by default when the building probe finds fewer than 3 units.
# Set RENTAL_SEARCH_FALLBACK=0 to disable it, or override the Manhattan search areas below.
# RENTAL_SEARCH_FALLBACK=0
# RENTAL_SEARCH_AREAS=all-downtown,all-midtown,all-upper-east-side,all-upper-west-side,all-upper-manhattan
# RENTAL_SEARCH_FALLBACK_LIMIT=50
# Pace unit probes/search calls to avoid RapidAPI 429s when one building fan-outs across many unit URLs.
# RAPIDAPI_RENTAL_REQUEST_DELAY_MS=250
# RAPIDAPI_RENTAL_RATE_LIMIT_RETRY_MS=1500

# OpenAI – broker/agent contact enrichment, digest summaries, dossier/deal analysis
OPENAI_API_KEY=
# Optional: general/lightweight model for enrichment flows (default: gpt-4o).
# Use API model ids such as gpt-5.5; common shorthand like 5.5 is normalized by the API service.
# OPENAI_MODEL=gpt-4o
# Optional: high-reasoning model for dossier, OM, and deal scoring flows (default: gpt-5.5)
# OPENAI_COMPLEX_ANALYSIS_MODEL=gpt-5.5
# Optional: targeted overrides for individual complex flows
# OPENAI_DOSSIER_MODEL=gpt-5.5
# OPENAI_DEAL_SCORING_MODEL=gpt-5.5
# OPENAI_OM_MODEL=gpt-5.5
# Optional: override for price history extraction only
# OPENAI_PRICE_HISTORY_MODEL=gpt-4o

# CORS: allow requests from frontend
# Local:    http://localhost:3000
# Render:   https://re-sourcing-web.onrender.com
CORS_ORIGIN=https://re-sourcing-web.onrender.com

# NYC Geoclient – optional; address → BBL/BIN (used by test script; main app gets BBL from listing extra or permit API).
# Get key at https://api-portal.nyc.gov (subscribe to geoclient-current-v2).
# GEOCLIENT_SUBSCRIPTION_KEY=

# NYC Open Data (Socrata) – optional but recommended. Used for all Open Data calls (permits, zoning, CO, HPD, violations, etc.). Set on Render to avoid rate limits.
# Get a token: https://data.cityofnewyork.us (sign in → profile → Create New App Token) or https://dev.socrata.com
# SOCRATA_APP_TOKEN=
# Permit enrichment rate limit (ms between property requests when batching)
# PERMITS_RATE_LIMIT_DELAY_MS=300
# Batch size for CLI/cron --all (default 50)
# PERMITS_BATCH_SIZE=50

# Gmail (inbox monitoring + send inquiry emails): OAuth2 client + refresh token. Use OAuth 2.0 Playground with scopes gmail.readonly and gmail.send.
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# Optional: protect POST /api/cron/process-inbox (header X-Cron-Secret or Authorization: Bearer <secret>)
# PROCESS_INBOX_CRON_SECRET=
# Optional: base path for inquiry attachment files (default: uploads/inquiry-docs)
# INQUIRY_DOCS_PATH=
# Optional: base path for user-uploaded property documents (default: uploads/property-docs)
# UPLOADED_DOCS_PATH=
# Optional: base path for generated dossier/Excel files (default: uploads/generated-docs). Used by Deal Dossier flow.
# GENERATED_DOCS_PATH=
