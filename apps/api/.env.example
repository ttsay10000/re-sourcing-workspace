# NYC Real Estate API (RapidAPI)
# Get your key at https://rapidapi.com/realestator/api/nyc-real-estate-api
RAPIDAPI_KEY=your_rapidapi_key_here

# OpenAI (broker + price-history enrichment; GPT-5 family per https://developers.openai.com/api/docs/guides/latest-model)
OPENAI_API_KEY=
# Optional: default model for all enrichment (default: gpt-5.2). Use gpt-5-mini for cost/speed.
# OPENAI_MODEL=gpt-5-mini
# Optional: override for price history only.
# OPENAI_PRICE_HISTORY_MODEL=gpt-5.2

# CORS: allow requests from frontend
# Local:    http://localhost:3000
# Render:   https://re-sourcing-web.onrender.com
CORS_ORIGIN=https://re-sourcing-web.onrender.com

# NYC Geoclient – optional; reverse geocode lat/lon → BBL/BIN for permit + 7 enrichment modules when listing has no BBL in extra.
# v1 (lat/lon): Get keys at https://developer.cityofnewyork.us/
# GEOCLIENT_APP_ID=
# GEOCLIENT_APP_KEY=
# v2 (address → BBL/BIN): Get key at https://api-portal.nyc.gov (subscribe to geoclient-current-v2)
# GEOCLIENT_SUBSCRIPTION_KEY=

# NYC Open Data (Socrata) – optional; improves rate limits for DOB permit enrichment
# SOCRATA_APP_TOKEN=
# Permit enrichment rate limit (ms between property requests when batching)
# PERMITS_RATE_LIMIT_DELAY_MS=300
# Batch size for CLI/cron --all (default 50)
# PERMITS_BATCH_SIZE=50
